{
  "kind": "collectionType",
  "collectionName": "tierlist_changelogs",
  "info": {
    "singularName": "tierlist-changelog",
    "pluralName": "tierlist-changelogs",
    "displayName": "Tierlist Changelog",
    "description": "История изменений тирлиста"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "version": {
      "type": "string",
      "required": true
    },
    "date": {
      "type": "date",
      "required": true
    },
    "changes": {
      "type": "richtext",
      "required": true
    },
    "changelogType": {
      "type": "enumeration",
      "enum": [
        "релиз",
        "игроки",
        "калибровка",
        "турнир",
        "ребаланс"
      ]
    }
  }
}
